# Required: @clerk/nextjs@6.x peer-depends on specific React 19 patch ranges
# (e.g. ~19.1.4) but this project uses react@19.1.0. The lockfile was generated
# with --legacy-peer-deps and CI needs this flag to reproduce that resolution.
# Remove once Clerk supports react@19.1.0 natively.
legacy-peer-deps=true
